# URL publica de la app. Cambia esto por tu dominio en produccion.
NEXT_PUBLIC_APP_URL=http://localhost:5155

# Base de datos PostgreSQL en el mismo docker-compose.
# Si corres la app fuera de Docker y PostgreSQL directo en el servidor, usa DB_HOST=127.0.0.1.
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_USER=ritmohub_user
DB_PASSWORD=
DB_NAME=musicapp

# En Docker Compose, PostgreSQL esta en la red interna local.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Crea/actualiza el esquema automaticamente al iniciar contra una DB nueva.
DB_INIT_SCHEMA=true

# Mantener false en produccion. Solo activar temporalmente para crear datos seed.
ENABLE_SEED_ROUTES=false
# ADMIN_SEED_PASSWORD=pon_una_password_admin_segura
# SEED_USERS_PASSWORD=pon_una_password_temporal_segura

# Stripe (cursos)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# PayPal (opcional)
# PAYPAL_ME_LINK=https://paypal.me/tuusuario
# PAYPAL_BUSINESS_EMAIL=tu-correo-paypal@example.com
