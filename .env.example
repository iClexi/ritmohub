# Public application URL. Change this for your own deployment.
NEXT_PUBLIC_APP_URL=https://ritmohub.example.com

# PostgreSQL database. Prefer DATABASE_URL when your platform supports it.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ritmohub_user
DB_PASSWORD=CHANGE_THIS_POSTGRES_PASSWORD
DB_NAME=ritmohub_db

DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Automatically create/update schema against a fresh database.
DB_INIT_SCHEMA=true

# SMTP for account verification and password recovery.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=RitmoHub <no-reply@example.com>

# Brevo Transactional SMS for verification/recovery codes.
BREVO_API_KEY=
BREVO_SMS_SENDER=RitmoHub

# Keep disabled in production unless intentionally seeding data.
ENABLE_SEED_ROUTES=false
SEED_ROUTE_TOKEN=
ADMIN_SEED_PASSWORD=
SEED_USERS_PASSWORD=

# Stripe course payments. Fill only when real payments are enabled.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional PayPal payment fallback.
PAYPAL_ME_LINK=
PAYPAL_BUSINESS_EMAIL=

# Optional OAuth providers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=

# Optional Sentry configuration.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
