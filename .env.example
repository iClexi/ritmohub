# URL publica de la app. Cambia esto si usas otro dominio en produccion.
NEXT_PUBLIC_APP_URL=https://ritmohub.iclexi.tech

# Base de datos PostgreSQL instalada en el mismo servidor.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ritmohub_user
DB_PASSWORD=CAMBIA_ESTA_PASSWORD_POSTGRES
DB_NAME=ritmohub_db

DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Crea/actualiza el esquema automaticamente al iniciar contra una DB nueva.
DB_INIT_SCHEMA=true

# Mantener false en produccion. Solo activar temporalmente para crear datos seed.
ENABLE_SEED_ROUTES=false
SEED_ROUTE_TOKEN=
ADMIN_SEED_PASSWORD=
SEED_USERS_PASSWORD=

# Stripe (cursos). Completar solo si vas a activar pagos reales.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# PayPal (opcional)
PAYPAL_ME_LINK=
PAYPAL_BUSINESS_EMAIL=

# OAuth (opcional)
# Google Cloud Console > Google Auth Platform > Clients > OAuth 2.0 Client ID
# Authorized JavaScript origins:
#   http://localhost:5155
#   https://ritmohub.iclexi.tech
# Authorized redirect URIs:
#   http://localhost:5155/api/auth/oauth/google/callback
#   https://ritmohub.iclexi.tech/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
