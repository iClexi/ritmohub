# Opcion 1 (recomendada): una sola URL
# DATABASE_URL=postgresql://usuario:password@host:5432/musicapp

# Opcion 2: variables separadas
DB_HOST=206.189.224.149
DB_PORT=5432
DB_USER=ritmohub_public
DB_PASSWORD=pon_una_password_aqui
DB_NAME=musicapp

# SSL para PostgreSQL remoto (VPS/Cloud)
# true  -> habilita TLS
# false -> sin TLS
DB_SSL=true

# Si el certificado del servidor es self-signed, usa false temporalmente.
# En produccion con CA valida, mantener true.
DB_SSL_REJECT_UNAUTHORIZED=true

# En produccion con rol sin permisos DDL, mantener en false.
# El esquema se crea una sola vez por admin usando db/init.sql
DB_INIT_SCHEMA=false

# Stripe (cursos)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# PayPal (opcional)
# PAYPAL_ME_LINK=https://paypal.me/tuusuario
# PAYPAL_BUSINESS_EMAIL=tu-correo-paypal@example.com
